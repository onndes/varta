{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VARTA",
  "version": "1.3.3",
  "identifier": "ua.varta.scheduler",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "VARTA",
        "width": 1200,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/shield.ico"
      }
    },
    "icon": [
      "icons/shield-32x32.png",
      "icons/shield-128x128.png",
      "icons/shield-128x128@2x.png",
      "icons/shield.icns",
      "icons/shield.ico"
    ]
  }
}
