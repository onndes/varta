{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VARTA",
  "version": "0.1.0",
  "identifier": "ua.varta.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "VARTA",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/shield-32x32.png",
      "icons/shield-128x128.png",
      "icons/shield-128x128@2x.png",
      "icons/shield.icns",
      "icons/shield.ico",
      "icons/shield-Square30x30Logo.png",
      "icons/shield-Square44x44Logo.png",
      "icons/shield-Square71x71Logo.png",
      "icons/shield-Square89x89Logo.png",
      "icons/shield-Square107x107Logo.png",
      "icons/shield-Square142x142Logo.png",
      "icons/shield-Square150x150Logo.png",
      "icons/shield-Square284x284Logo.png",
      "icons/shield-Square310x310Logo.png",
      "icons/shield-StoreLogo.png"
    ]
  }
}
